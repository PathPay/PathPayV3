modules = ["nodejs-24", "python-3.11", "nodejs-20"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { CI = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
packages = ["psmisc", "iproute", "lsof"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 80

[userenv]

[userenv.shared]
VITE_PORT = "5173"
API_PORT = "3000"

[[workflows.workflow]]
name = "Project"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "API Server"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'artifacts/api-server' || true && cd artifacts/api-server && PORT=3000 pnpm run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Frontend"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f vite || true && cd artifacts/pathpay && PORT=5173 BASE_PATH=/ pnpm run dev"
waitForPort = 5173
